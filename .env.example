# Application
APP_ENV=development
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
BASE_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql+asyncpg://hotel:hotel@db:5432/hotel
DATABASE_URL_SYNC=postgresql://hotel:hotel@db:5432/hotel

# Test Database (used by pytest)
TEST_DATABASE_URL=postgresql+asyncpg://hotel:hotel@db:5432/hotel_test

# Redis
REDIS_URL=redis://redis:6379/0

# Stripe
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# Google OAuth
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder

# Email (Resend)
RESEND_API_KEY=re_placeholder
EMAIL_FROM=noreply@yourdomain.com

# Superadmin seed (used in DB seed script)
SUPERADMIN_EMAIL=admin@yourdomain.com
SUPERADMIN_PASSWORD=change-me
